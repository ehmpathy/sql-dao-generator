{
  "name": "sql-dao-generator",
  "author": "ehmpathy",
  "description": "Generate data-access-objects from your domain-objects.",
  "version": "0.12.1",
  "repository": "ehmpathy/sql-dao-generator",
  "homepage": "https://github.com/ehmpathy/sql-dao-generator",
  "keywords": [
    "database",
    "schema",
    "dao",
    "database-access-objects",
    "sql",
    "typescript",
    "generator",
    "client",
    "types"
  ],
  "bugs": "https://github.com/ehmpathy/sql-dao-generator/issues",
  "engines": {
    "node": ">=12.0.0"
  },
  "packageManager": "pnpm@10.24.0",
  "oclif": {
    "commands": "./dist/contract/commands",
    "bin": "sql-dao-generator",
    "plugins": [
      "@oclif/plugin-help"
    ]
  },
  "types": "dist/index.d.ts",
  "bin": {
    "sql-dao-generator": "./bin/run"
  },
  "files": [
    "/bin",
    "/dist"
  ],
  "license": "MIT",
  "main": "dist/contract/index.js",
  "scripts": {
    "generate:cli-readme": "npm run build && oclif-dev readme",
    "build:ts": "tsc -p ./tsconfig.build.json",
    "provision:docker:extensions": "docker compose -f ./provision/docker/integration_test_db/docker-compose.yml exec -T postgres /root/provision-extensions.sh",
    "commit:with-cli": "npx cz",
    "fix:format:biome": "biome check --write",
    "fix:format:terraform": "echo 'no terraform'",
    "fix:format": "npm run fix:format:biome",
    "fix:lint": "biome check --write",
    "provision:docker:down": "docker compose -f ./provision/docker/integration_test_db/docker-compose.yml down",
    "fix": "npm run fix:format && npm run fix:lint",
    "build:artifact": "echo 'no artifact'",
    "build:clean:bun": "rm -f ./bin/*.bc",
    "build:clean:tsc": "(chmod -R u+w dist 2>/dev/null || true) && rm -rf dist/",
    "build:clean": "npm run build:clean:tsc && npm run build:clean:bun",
    "build:compile:tsc": "tsc -p ./tsconfig.build.json && tsc-alias -p ./tsconfig.build.json",
    "build:compile": "npm run build:compile:tsc && npm run build:compile:bun --if-present",
    "build": "npm run build:clean && npm run build:compile && npm run build:complete --if-present",
    "provision:docker:clear": "docker rm -f $(docker ps -a -f 'publish=7821' -q) 2>/dev/null || true && echo 'ensured port is available 👍'",
    "provision:docker:up": "docker compose -f ./provision/docker/integration_test_db/docker-compose.yml up -d --force-recreate --build --renew-anon-volumes",
    "provision:docker:await": "docker compose -f ./provision/docker/integration_test_db/docker-compose.yml exec -T postgres /root/wait-for-postgres.sh",
    "provision:integration-test-db": "npm run provision:docker:clear && npm run provision:docker:up && npm run provision:docker:await && npm run provision:docker:extensions",
    "start:testdb": "npm run provision:integration-test-db",
    "test:commits": "LAST_TAG=$(git describe --tags --abbrev=0 @^ 2> /dev/null || git rev-list --max-parents=0 HEAD) && npx commitlint --from $LAST_TAG --to HEAD --verbose",
    "test:types": "tsc -p ./tsconfig.json --noEmit",
    "test:format:terraform": "echo 'no terraform'",
    "test:integration:provision-generated-files-to-import": "npx jest src/logic/commands/generate.test.ts",
    "test:format:biome": "biome format",
    "test:format": "npm run test:format:biome",
    "test:lint:deps": "npx depcheck -c ./.depcheckrc.yml",
    "test:lint:biome": "biome check --diagnostic-level=error",
    "test:lint:biome:all": "biome check",
    "test:lint": "npm run test:lint:biome && npm run test:lint:cycles && npm run test:lint:deps",
    "test:unit": "set -eu && jest -c ./jest.unit.config.ts --forceExit --verbose --passWithNoTests $([ -n \"${CI:-}\" ] && echo '--ci') $([ \"${THOROUGH:-}\" != \"true\" ] && echo '--changedSince=main') $([ \"${RESNAP:-}\" = \"true\" ] && echo '--updateSnapshot')",
    "test:integration": "set -eu && npm run test:integration:provision-generated-files-to-import && jest -c ./jest.integration.config.ts --forceExit --verbose --passWithNoTests $([ -n \"${CI:-}\" ] && echo '--ci') $([ \"${THOROUGH:-}\" != \"true\" ] && echo '--changedSince=main') $([ \"${RESNAP:-}\" = \"true\" ] && echo '--updateSnapshot')",
    "test:acceptance:locally": "set -eu && npm run build && LOCALLY=true jest -c ./jest.acceptance.config.ts --forceExit --verbose --runInBand --passWithNoTests $([ \"${RESNAP:-}\" = \"true\" ] && echo '--updateSnapshot')",
    "test": "set -eu && npm run test:commits && npm run test:types && npm run test:format && npm run test:lint && npm run test:unit && npm run test:integration && npm run test:acceptance:locally",
    "test:acceptance": "set -eu && npm run build && jest -c ./jest.acceptance.config.ts --forceExit --verbose --runInBand --passWithNoTests $([ -n \"${CI:-}\" ] && echo '--ci') $([ \"${RESNAP:-}\" = \"true\" ] && echo '--updateSnapshot')",
    "prepush": "npm run test && npm run build",
    "prepublish": "npm run build",
    "preversion": "npm run prepush",
    "postversion": "git push origin HEAD --tags --no-verify",
    "prepare:husky": "husky install && chmod ug+x .husky/*",
    "prepare:rhachet": "rhachet init --hooks --roles mechanic behaver driver architect ergonomist reviewer dreamer dispatcher",
    "prepare": "if [ -e .git ] && [ -z $CI ]; then npm run prepare:husky && npm run prepare:rhachet; fi",
    "test:lint:cycles": "dpdm --no-warning --no-tree --transform --exit-code circular:1 --exclude \"$(yq -r '.exclude | join(\"|\") // \"^$\"' .dpdmrc.yaml)\" 'src/**/!(*.test).ts'",
    "upgrade:rhachet": "rhachet upgrade"
  },
  "dependencies": {
    "@oclif/core": "3.26.6",
    "@oclif/plugin-help": "6.0.22",
    "chalk": "2.4.2",
    "change-case": "4.1.1",
    "domain-objects": "0.31.13",
    "domain-objects-metadata": "0.7.7",
    "fast-glob": "3.2.2",
    "helpful-errors": "1.7.3",
    "lodash.omit": "4.5.0",
    "oclif": "4.11.3",
    "shelljs": "0.10.0",
    "simple-async-tasks": "1.4.2",
    "type-fns": "1.21.2",
    "uuid": "9.0.0",
    "visualogic": "1.3.2",
    "yaml": "2.9.0",
    "zod": "4.3.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.8",
    "@commitlint/cli": "19.5.0",
    "@commitlint/config-conventional": "19.5.0",
    "@jest/globals": "30.2.0",
    "@oclif/dev-cli": "1.26.10",
    "@swc/core": "1.15.3",
    "@swc/jest": "0.2.39",
    "@tsconfig/node20": "20.1.5",
    "@tsconfig/strictest": "2.0.5",
    "@types/change-case": "2.3.1",
    "@types/jest": "30.0.0",
    "@types/lodash.omit": "4.5.9",
    "@types/node": "22.15.21",
    "@types/pg": "8.6.1",
    "@types/shelljs": "0.8.9",
    "@types/uuid": "9.0.0",
    "@types/yaml": "1.0.2",
    "@types/yesql": "3.2.1",
    "cz-conventional-changelog": "3.3.0",
    "declapract": "0.13.21",
    "declapract-typescript-ehmpathy": "0.47.74",
    "declastruct": "1.9.1",
    "declastruct-github": "1.4.0",
    "depcheck": "1.4.3",
    "dpdm": "4.0.1",
    "esbuild-register": "3.6.0",
    "husky": "8.0.3",
    "jest": "30.2.0",
    "pg": "8.6.0",
    "procedure-fns": "1.0.0",
    "rhachet": "1.41.17",
    "rhachet-brains-anthropic": "0.4.1",
    "rhachet-brains-xai": "0.3.3",
    "rhachet-roles-bhrain": "0.28.0",
    "rhachet-roles-bhuild": "0.21.15",
    "rhachet-roles-ehmpathy": "1.35.12",
    "rhachet-roles-rhachet": "0.1.7",
    "sql-code-generator": "0.10.2",
    "sql-schema-control": "1.7.3",
    "sql-schema-generator": "0.25.3",
    "test-fns": "1.15.8",
    "tsc-alias": "1.8.10",
    "tsx": "4.20.6",
    "typescript": "5.4.5",
    "uuid": "3.3.2",
    "yalc": "1.0.0-pre.53",
    "yesql": "3.2.2"
  },
  "peerDependencies": {
    "sql-code-generator": "0.10.2",
    "sql-schema-generator": "0.25.3"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  }
}
